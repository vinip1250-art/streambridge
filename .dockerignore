<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StreamBridge – Configuração</title>
  <style>
    :root {
      --bg: #0f0f0f; --surface: #1a1a1a; --surface2: #242424;
      --border: #333; --accent: #7c3aed; --accent-hover: #6d28d9;
      --text: #f1f1f1; --muted: #888;
      --success: #22c55e; --error: #ef4444; --warn: #f59e0b;
      --radius: 10px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg); color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      min-height: 100vh; display: flex;
      align-items: flex-start; justify-content: center; padding: 32px 16px;
    }
    .card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); width: 100%; max-width: 560px; padding: 36px;
    }
    .logo { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }
    .logo img { width: 36px; height: 36px; }
    .logo h1 { font-size: 20px; font-weight: 700; letter-spacing: -0.3px; }
    .logo span { font-size: 12px; color: var(--muted); display: block; font-weight: 400; }

    .section-header {
      display: flex; align-items: center; gap: 10px;
      margin: 28px 0 16px;
    }
    .section-header:first-of-type { margin-top: 0; }
    .badge {
      font-size: 10px; font-weight: 700; padding: 2px 8px;
      border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .badge-primary   { background: rgba(124,58,237,.2); color: #a78bfa; border: 1px solid rgba(124,58,237,.4); }
    .badge-secondary { background: rgba(245,158,11,.15); color: var(--warn); border: 1px solid rgba(245,158,11,.3); }
    .badge-optional  { background: rgba(136,136,136,.15); color: var(--muted); border: 1px solid rgba(136,136,136,.3); }
    .section-title { font-size: 13px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }

    .instance-box {
      background: var(--surface2); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 20px; margin-bottom: 12px;
    }
    .instance-box.secondary-box { border-color: rgba(245,158,11,.25); }

    .field { margin-bottom: 14px; }
    label { display: block; font-size: 13px; color: var(--muted); margin-bottom: 6px; }
    input[type="text"], input[type="password"], input[type="url"] {
      width: 100%; background: var(--bg); border: 1px solid var(--border);
      border-radius: 7px; color: var(--text); font-size: 14px;
      padding: 10px 12px; outline: none; transition: border-color .15s;
    }
    input:focus { border-color: var(--accent); }

    .row { display: flex; gap: 8px; }
    .row input { flex: 1; }
    .row button {
      padding: 10px 14px; background: var(--surface2);
      border: 1px solid var(--border); border-radius: 7px;
      color: var(--text); font-size: 12px; cursor: pointer; white-space: nowrap;
    }
    .row button:hover { background: var(--border); }

    .btn {
      width: 100%; padding: 12px; border: none; border-radius: 7px;
      font-size: 14px; font-weight: 600; cursor: pointer;
      transition: background .15s, opacity .15s; margin-top: 6px;
    }
    .btn-secondary {
      background: var(--surface2); color: var(--text);
      border: 1px solid var(--border); margin-bottom: 10px;
    }
    .btn-secondary:hover { background: var(--border); }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-primary:disabled { opacity: .4; cursor: not-allowed; }

    .status {
      font-size: 13px; padding: 10px 12px; border-radius: 7px;
      margin-top: 12px; display: none;
    }
    .status.success { background: rgba(34,197,94,.1); border: 1px solid rgba(34,197,94,.3); color: var(--success); }
    .status.error   { background: rgba(239,68,68,.1);  border: 1px solid rgba(239,68,68,.3);  color: var(--error); }
    .status.loading { background: rgba(124,58,237,.1); border: 1px solid rgba(124,58,237,.3); color: #a78bfa; }

    .divider { height: 1px; background: var(--border); margin: 24px 0; }
    .info { font-size: 12px; color: var(--muted); margin-top: 8px; line-height: 1.6; }

    .secondary-toggle {
      display: flex; align-items: center; gap: 10px; cursor: pointer;
      padding: 12px 16px; background: var(--surface2);
      border: 1px dashed rgba(245,158,11,.3); border-radius: var(--radius);
      margin-bottom: 12px; transition: border-color .15s;
    }
    .secondary-toggle:hover { border-color: var(--warn); }
    .secondary-toggle-text { font-size: 14px; font-weight: 600; color: var(--warn); }
    .secondary-toggle-sub  { font-size: 12px; color: var(--muted); }
    .chevron { color: var(--warn); transition: transform .2s; }
    .chevron.open { transform: rotate(180deg); }

    #secondaryForm { display: none; }
    #secondaryForm.visible { display: block; }

    #resultArea { margin-top: 20px; }
    #installBtn { display: none; text-decoration: none; text-align: center; }
  </style>
</head>
<body>
<div class="card">
  <div class="logo">
    <img src="https://jellyfin.org/images/logo.svg" alt="Jellyfin" onerror="this.style.display='none'" />
    <div>
      <h1>StreamBridge</h1>
      <span>Jellyfin → Stremio · Multi-instância</span>
    </div>
  </div>

  <!-- ── Instância Primária ── -->
  <div class="section-header">
    <span class="badge badge-primary">Primária</span>
    <span class="section-title">VPS / Principal</span>
  </div>

  <div class="instance-box">
    <div class="field">
      <label>Nome do servidor</label>
      <input type="text" id="p_serverName" placeholder="Jellyfin VPS" value="Jellyfin VPS" />
    </div>
    <div class="field">
      <label>URL do servidor</label>
      <input type="url" id="p_serverUrl" placeholder="https://jellyfin.exemplo.com" />
    </div>
    <div class="field">
      <label>Usuário</label>
      <input type="text" id="p_username" placeholder="admin" />
    </div>
    <div class="field">
      <label>Senha</label>
      <input type="password" id="p_password" placeholder="••••••••" />
    </div>
    <button class="btn btn-secondary" onclick="authenticate('p')">🔑 Buscar User ID e API Key</button>
    <div class="field" style="margin-top:14px">
      <label>User ID</label>
      <input type="text" id="p_userId" placeholder="preenchido automaticamente" />
    </div>
    <div class="field">
      <label>API Key</label>
      <input type="text" id="p_apiKey" placeholder="preenchida automaticamente" />
    </div>
    <div id="p_authStatus" class="status"></div>
  </div>

  <!-- ── Instância Secundária (opcional) ── -->
  <div class="section-header" style="margin-top:20px">
    <span class="badge badge-secondary">Secundária</span>
    <span class="section-title">PC Local / Transcodificação HD</span>
    <span class="badge badge-optional" style="margin-left:auto">Opcional</span>
  </div>

  <div class="secondary-toggle" onclick="toggleSecondary()">
    <span class="chevron" id="chevron">▼</span>
    <div>
      <div class="secondary-toggle-text">+ Adicionar instância secundária</div>
      <div class="secondary-toggle-sub">Priorizada para streams com melhor transcodificação</div>
    </div>
  </div>

  <div id="secondaryForm">
    <div class="instance-box secondary-box">
      <div class="field">
        <label>Nome do servidor</label>
        <input type="text" id="s_serverName" placeholder="PC Local" value="PC Local" />
      </div>
      <div class="field">
        <label>URL do servidor <span style="color:var(--warn)">(precisa ser acessível remotamente)</span></label>
        <input type="url" id="s_serverUrl" placeholder="http://SEU-IP-PUBLICO:8096" />
      </div>
      <div class="field">
        <label>Usuário</label>
        <input type="text" id="s_username" placeholder="admin" />
      </div>
      <div class="field">
        <label>Senha</label>
        <input type="password" id="s_password" placeholder="••••••••" />
      </div>
      <button class="btn btn-secondary" onclick="authenticate('s')">🔑 Buscar User ID e API Key</button>
      <div class="field" style="margin-top:14px">
        <label>User ID</label>
        <input type="text" id="s_userId" placeholder="preenchido automaticamente" />
      </div>
      <div class="field">
        <label>API Key</label>
        <input type="text" id="s_apiKey" placeholder="preenchida automaticamente" />
      </div>
      <div id="s_authStatus" class="status"></div>
      <p class="info">
        ⚠️ O PC Local precisa ter porta aberta (ex: <code>8096</code>) ou VPN para que o Stremio consiga acessar os streams diretamente.<br/>
        O health check é feito pelo addon na VPS — se o PC estiver offline, apenas a instância primária será usada.
      </p>
    </div>
  </div>

  <div class="divider"></div>

  <!-- ── Gerar ── -->
  <div class="section-header" style="margin-top:0">
    <span class="section-title" style="font-size:13px">Gerar e instalar</span>
  </div>

  <p class="info">Cada usuário recebe um link de manifest com as credenciais embutidas (base64).</p>

  <button class="btn btn-primary" onclick="generateLink()" style="margin-top:14px">
    ⚙️ Gerar link de manifest
  </button>

  <div id="resultArea" style="display:none">
    <label style="display:block; margin:16px 0 8px">Seu manifest URL:</label>
    <div class="row">
      <input type="text" id="manifestUrl" readonly />
      <button onclick="copyUrl()">Copiar</button>
    </div>
    <p class="info" style="margin-top:10px">
      Cole em <strong>Stremio → Addons → "+" → URL do addon</strong>, ou clique em Instalar.
    </p>
    <a id="installBtn" class="btn btn-primary" style="margin-top:14px; display:block">
      📺 Instalar no Stremio
    </a>
  </div>
</div>

<script>
  let secondaryOpen = false;

  function toggleSecondary() {
    secondaryOpen = !secondaryOpen;
    document.getElementById('secondaryForm').classList.toggle('visible', secondaryOpen);
    document.getElementById('chevron').classList.toggle('open', secondaryOpen);
    document.querySelector('.secondary-toggle-text').textContent =
      secondaryOpen ? '− Remover instância secundária' : '+ Adicionar instância secundária';
  }

  async function authenticate(prefix) {
    const url      = document.getElementById(`${prefix}_serverUrl`).value.trim().replace(/\/$/, '');
    const username = document.getElementById(`${prefix}_username`).value.trim();
    const password = document.getElementById(`${prefix}_password`).value;
    const status   = document.getElementById(`${prefix}_authStatus`);

    if (!url || !username) {
      showStatus(status, 'error', 'Preencha a URL e o usuário.');
      return;
    }
    showStatus(status, 'loading', 'Autenticando…');

    try {
      const resp = await fetch(`${url}/Users/AuthenticateByName`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Emby-Authorization': 'MediaBrowser Client="StreamBridge", Device="Browser", DeviceId="streambridge-config", Version="2.2"',
        },
        body: JSON.stringify({ Username: username, Pw: password }),
      });

      if (!resp.ok) throw new Error(`HTTP ${resp.status}: ${(await resp.text()).slice(0, 120)}`);

      const data = await resp.json();
      document.getElementById(`${prefix}_userId`).value = data.User?.Id ?? '';
      document.getElementById(`${prefix}_apiKey`).value = data.AccessToken ?? '';
      showStatus(status, 'success', `✅ Autenticado como "${data.User?.Name}"!`);
    } catch (err) {
      showStatus(status, 'error', `Erro: ${err.message}`);
    }
  }

  function generateLink() {
    const p = {
      jellyfinUrl: document.getElementById('p_serverUrl').value.trim().replace(/\/$/, ''),
      userId:      document.getElementById('p_userId').value.trim(),
      apiKey:      document.getElementById('p_apiKey').value.trim(),
      serverName:  document.getElementById('p_serverName').value.trim() || 'Jellyfin VPS',
    };

    if (!p.jellyfinUrl || !p.userId || !p.apiKey) {
      alert('Preencha todos os campos da instância primária.\nUse o botão "Buscar User ID e API Key" ou preencha manualmente.');
      return;
    }

    let config;

    if (secondaryOpen) {
      const s = {
        jellyfinUrl: document.getElementById('s_serverUrl').value.trim().replace(/\/$/, ''),
        userId:      document.getElementById('s_userId').value.trim(),
        apiKey:      document.getElementById('s_apiKey').value.trim(),
        serverName:  document.getElementById('s_serverName').value.trim() || 'PC Local',
      };

      if (s.jellyfinUrl && (!s.userId || !s.apiKey)) {
        alert('Preencha User ID e API Key da instância secundária, ou deixe a URL em branco para ignorá-la.');
        return;
      }

      config = s.jellyfinUrl ? { primary: p, secondary: s } : { primary: p };
    } else {
      config = { primary: p };
    }

    const encoded     = btoa(JSON.stringify(config));
    const manifestUrl = `${window.location.origin}/${encoded}/manifest.json`;

    document.getElementById('manifestUrl').value = manifestUrl;
    document.getElementById('installBtn').href   =
      `stremio://${manifestUrl.replace(/^https?:\/\//, '')}`;
    document.getElementById('resultArea').style.display = 'block';
    document.getElementById('installBtn').style.display = 'block';
  }

  function copyUrl() {
    const input = document.getElementById('manifestUrl');
    input.select();
    document.execCommand('copy');
    const btn = input.nextElementSibling;
    btn.textContent = '✅ Copiado!';
    setTimeout(() => (btn.textContent = 'Copiar'), 2000);
  }

  function showStatus(el, type, msg) {
    el.textContent   = msg;
    el.className     = `status ${type}`;
    el.style.display = 'block';
  }

  ['p_username', 'p_password'].forEach(id =>
    document.getElementById(id).addEventListener('keydown', e => { if (e.key === 'Enter') authenticate('p'); }));
  ['s_username', 's_password'].forEach(id =>
    document.getElementById(id).addEventListener('keydown', e => { if (e.key === 'Enter') authenticate('s'); }));
</script>
</body>
</html>
